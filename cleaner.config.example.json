{
  "baseUrl": "https://your-host.example.com/v0/management",
  "managementKey": "",
  "mode": "reconcile",
  "dryRun": true,
  "concurrency": 8,
  "retries": 0,
  "disableAfterFailures": 2,
  "output": "report.json",
  "includeDisabled": true,
  "stateFile": "auth-state.json",
  "recoverAfterSuccesses": 2,
  "healthSampleRate": 0.1,
  "maxProbeCandidatesPerRun": 200,
  "metrics": {
    "enabled": false,
    "output": "metrics.prom"
  }
}
